# Identificação
APP_NAME=PLI Reporta
APP_ENV=development

# Banco de dados do PLI Reporta (dados próprios da aplicação)
# Dev rápido (sem dependências): SQLite
DATABASE_URL=sqlite:///./pli_reporta.db
#
# Produção / integração: PostgreSQL da VM (mesmo servidor do SIGMA, banco próprio).
# Crie o banco com: python scripts/provision_pli_db.py  (ver docs/OPERACAO.md)
# Via túnel SSH local (scripts/sigma-tunnel.ps1 -> porta 15433):
#   DATABASE_URL=postgresql+psycopg://pli_user:SENHA@127.0.0.1:15433/pli_reporta
# Rodando na própria VM (porta direta 5433):
#   DATABASE_URL=postgresql+psycopg://pli_user:SENHA@127.0.0.1:5433/pli_reporta

# Storage de mídia
PHOTO_STORAGE_DIR=./backend/storage/photos
PUBLIC_BASE_URL=http://localhost:8080

# Segurança
SECRET_KEY=troque-em-producao-use-segredo-longo-e-aleatorio
CAPTURE_NONCE_TTL_SECONDS=300
CAPTURE_NONCE_OFFLINE_TTL_SECONDS=172800

# Moderação / acesso restrito (fallback local — dev/teste sem SIGMA)
MODERATOR_USERNAME=
MODERATOR_PASSWORD=

# SIGMA-PLI — autenticação de gestores (/acesso)
# Preferencial: API HTTP (sem túnel SSH)
SIGMA_API_BASE_URL=http://56.125.163.194

# Fallback opcional: PostgreSQL direto (exige túnel scripts/sigma-tunnel.ps1)
SIGMA_DATABASE_URL=
SIGMA_POSTGRES_HOST=
SIGMA_POSTGRES_PORT=15433
SIGMA_POSTGRES_DATABASE=sigma_pli_qr53
SIGMA_POSTGRES_USER=sigma_user
SIGMA_POSTGRES_PASSWORD=
SIGMA_POSTGRES_SSLMODE=disable

AUTO_PUBLISH_THRESHOLD=0.70
AUTO_DISCARD_THRESHOLD=0.30
MANIFESTATION_PUBLISH_THRESHOLD=0.75
MANIFESTATION_DISCARD_THRESHOLD=0.40

# Snap à malha viária (caminho opcional para um roads.geojson local)
ROADS_GEOJSON_PATH=

# CORS para o roteador
ALLOWED_ORIGINS=*
