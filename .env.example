# Identificação
APP_NAME=PLI Reporta
APP_ENV=development

# Banco de dados (SQLite no MVP; troque para postgresql+psycopg em produção)
DATABASE_URL=sqlite:///./pli_reporta.db

# Storage de mídia
PHOTO_STORAGE_DIR=./backend/storage/photos
PUBLIC_BASE_URL=http://localhost:8080

# Segurança
SECRET_KEY=troque-em-producao-use-segredo-longo-e-aleatorio
CAPTURE_NONCE_TTL_SECONDS=300

# Moderação
AUTO_PUBLISH_THRESHOLD=0.70
AUTO_DISCARD_THRESHOLD=0.30

# Snap à malha viária (caminho opcional para um roads.geojson local)
ROADS_GEOJSON_PATH=

# CORS para o roteador
ALLOWED_ORIGINS=*
