# Variáveis para `docker compose up` (teste local da imagem).
# Copie para .env.docker e preencha os valores reais:
#   copy .env.docker.example .env.docker
#
# Na VM (produção), use docker-compose.vm.yml com --network=host e
# DATABASE_URL apontando para 127.0.0.1:5433.

APP_ENV=production
APP_NAME=PLI Reporta
PORT=8080

# Postgres dedicado pli_reporta (VM ou túnel local 15433)
DATABASE_URL=postgresql+psycopg://pli_user:SENHA@host.docker.internal:15433/pli_reporta

# Autenticação de gestores
SIGMA_API_BASE_URL=http://56.125.163.194

# URLs e storage (volumes montados no compose)
PUBLIC_BASE_URL=http://localhost:8081
PHOTO_STORAGE_DIR=/app/backend/storage/photos

# Segurança — gere um valor forte em produção
SECRET_KEY=troque-em-producao-use-segredo-longo-e-aleatorio

# GeoJSON opcionais (montar volume na VM se usar escopo DER completo)
# ROADS_GEOJSON_PATH=/app/data/malha_rodoviaria.geojson
# URBAN_GEOJSON_PATH=/app/data/ibge_mancha_urbana.geojson
# MUNICIPIOS_GEOJSON_PATH=/app/data/ibge_municipios_sp.geojson

ALLOWED_ORIGINS=*
