# Segredos para docker-compose.vm.yml na VM.
# Copie para .env.vm na VM (/opt/pli-reporta/.env.vm) e preencha.

PLI_DB_PASSWORD=
SECRET_KEY=

# URL publica (sslip.io ou dominio definitivo)
PUBLIC_BASE_URL=http://pli-reporta.56-125-163-194.sslip.io

# API do SIGMA no host (Nginx :80)
SIGMA_API_BASE_URL=http://host.docker.internal

# GeoJSON opcionais (montar volume se usar escopo DER completo)
# ROADS_GEOJSON_PATH=/app/data/geojson/malha_rodoviaria.geojson
# URBAN_GEOJSON_PATH=/app/data/geojson/ibge_mancha_urbana.geojson
# MUNICIPIOS_GEOJSON_PATH=/app/data/geojson/ibge_municipios_sp.geojson
